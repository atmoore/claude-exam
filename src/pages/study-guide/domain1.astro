        <text x="100" y="226" text-anchor="middle" font-family="'Inter',sans-serif" font-size="12" font-weight="600" fill="#5e5d59">Web Search</text>
        <text x="100" y="242" text-anchor="middle" font-family="'Inter',sans-serif" font-size="11" fill="#87867f">Subagent</text>

