        <line x1="210" y1="110" x2="100" y2="185" stroke="#d1cdc4" stroke-width="2"/>
        <line x1="260" y1="124" x2="260" y2="185" stroke="#d1cdc4" stroke-width="2"/>
        <line x1="310" y1="110" x2="420" y2="185" stroke="#d1cdc4" stroke-width="2"/>

        <!-- Arrows -->
        <polygon points="100,185 108,178 104,188" fill="#d1cdc4"/>
        <polygon points="260,185 254,176 266,176" fill="#d1cdc4"/>
        <polygon points="420,185 412,178 416,188" fill="#d1cdc4"/>

